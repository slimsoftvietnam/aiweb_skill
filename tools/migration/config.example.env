AIWEB_BASE=http://localhost/aiweb
# Root folder of the AIWeb PHP repo, the folder that contains aiweb_core/.
AIWEB_ROOT=D:/Xampp/htdocs/aiweb
MIGRATION_API_KEY=aiw_REPLACE_ME

# Apache / local XAMPP default: /uploads is rewritten to aiweb_core/uploads.
# MIGRATION_UPLOAD_PREFIX=uploads

# Nginx document root mode: public URLs point directly to aiweb_core/uploads.
# MIGRATION_USE_NGINX_ROOT_PATH=1
# or:
# MIGRATION_UPLOAD_PREFIX=aiweb_core/uploads
