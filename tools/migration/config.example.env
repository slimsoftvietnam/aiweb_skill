AIWEB_BASE=http://localhost/aiweb
# Đường dẫn repo aiweb (có thư mục aiweb_core/) — bắt buộc khi chạy từ repo aiweb_skill
AIWEB_ROOT=D:/Xampp/htdocs/aiweb
# Apache / local XAMPP (mặc định — .htaccess rewrite /uploads/)
# MIGRATION_UPLOAD_PREFIX=uploads

# Nginx document root (slimcrm.vn, ai.slim.vn, …) — URL trực tiếp aiweb_core/uploads/
# MIGRATION_USE_NGINX_ROOT_PATH=1
# hoặc:
# MIGRATION_UPLOAD_PREFIX=aiweb_core/uploads
